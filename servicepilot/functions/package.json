{
  "name": "servicepilot-functions",
  "description": "Firebase Cloud Functions for ServicePilot",
  "scripts": {
    "build": "cp -r src/* lib/ 2>/dev/null || true",
    "serve": "firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "18"
  },
  "main": "src/index.js",
  "dependencies": {
    "firebase-admin": "^11.11.1",
    "firebase-functions": "^4.5.0",
    "nodemailer": "^6.9.7",
    "xlsx": "^0.18.5",
    "date-fns": "^3.0.6"
  },
  "private": true
}
